<% content_for :title, "Delay Statistics — Wien Live" %>


<div class="delays-page">
  <header class="delays__header">
    <div class="delays__brand">
      <p class="delays__eyebrow">Vienna public transit</p>
      <h1>Delay Statistics</h1>
      <p class="delays__subtitle">
        <% if @latest_at %>
          Last updated <%= time_ago_in_words(@latest_at) %> ago · 24-hour rolling window
        <% else %>
          Collecting data — statistics will appear once snapshots accumulate.
        <% end %>
      </p>
    </div>
    <nav class="delays__nav">
      <%= link_to root_path, class: "delays__back-link" do %>
        <i class="fa-solid fa-map" aria-hidden="true"></i> Live Map
      <% end %>
    </nav>
  </header>

  <% if @latest_at.nil? %>
    <div class="delays__empty">
      <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
      <p>No data yet. Start the background worker with <code>bin/jobs</code> to begin collecting snapshots.</p>
    </div>
  <% else %>
    <!-- Summary cards -->
    <section class="delays__summary">
      <div class="summary-card">
        <span class="summary-card__value"><%= @current_health.size %></span>
        <span class="summary-card__label">Lines monitored</span>
      </div>
      <div class="summary-card summary-card--ok">
        <span class="summary-card__value"><%= @current_health.count { |l| l.status == "ok" } %></span>
        <span class="summary-card__label">On time</span>
      </div>
      <div class="summary-card summary-card--warning">
        <span class="summary-card__value"><%= @current_health.select(&:delayed?).size %></span>
        <span class="summary-card__label">Delayed</span>
      </div>
      <div class="summary-card summary-card--severe">
        <span class="summary-card__value"><%= @current_health.count { |l| l.status == "disrupted" } %></span>
        <span class="summary-card__label">Disrupted</span>
      </div>
    </section>

    <!-- Network-wide delay trend -->
    <section class="delays__chart-section">
      <h2>Network Avg Delay (24h)</h2>
      <p class="delays__chart-hint">Average delay in minutes across all lines, 5-minute intervals</p>
      <%= area_chart @delay_over_time,
        suffix: " min",
        colors: ["#f59e0b"],
        library: {
          scales: { y: { beginAtZero: true } },
          elements: { point: { radius: 0 }, line: { tension: 0.3 } },
          plugins: { legend: { display: false } }
        },
        height: "220px" %>
    </section>

    <!-- Reliability table -->
    <section class="delays__chart-section">
      <h2>Line Reliability (24h)</h2>
      <p class="delays__chart-hint">Percentage of time each line was on-time — lower = less reliable</p>

      <div class="delays__table-wrap">
        <table class="delays__table">
          <thead>
            <tr>
              <th>Line</th>
              <th>Type</th>
              <th>Reliability</th>
              <th>Trend</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @reliability.each do |line, score, category, color| %>
              <tr>
                <td>
                  <%= link_to line_delays_path(line: line), class: "delays__line-link" do %>
                    <span class="delays__line-badge" style="background:<%= color || '#64748b' %>"><%= line %></span>
                  <% end %>
                </td>
                <td class="delays__category"><%= OebbTransitSupport::CATEGORY_CONFIG.dig(category, :label) || category %></td>
                <td><strong><%= score %>%</strong></td>
                <td class="delays__trend">—</td>
                <td>
                  <% if score >= 95 %>
                    <span class="reliability-badge reliability-badge--great">Excellent</span>
                  <% elsif score >= 80 %>
                    <span class="reliability-badge reliability-badge--good">Good</span>
                  <% elsif score >= 60 %>
                    <span class="reliability-badge reliability-badge--fair">Fair</span>
                  <% else %>
                    <span class="reliability-badge reliability-badge--poor">Poor</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Current line status -->
    <section class="delays__chart-section">
      <h2>Current Line Status</h2>
      <% @current_health.group_by(&:category).each do |category, lines| %>
        <% config = OebbTransitSupport::CATEGORY_CONFIG[category] || { label: category } %>
        <p class="delays__grid-category"><%= config[:label] %></p>
        <div class="delays__line-grid">
          <% lines.sort_by { |l| l.line.to_i == 0 ? l.line : l.line.to_i.to_s.rjust(5, "0") }.each do |line| %>
            <%= link_to line_delays_path(line: line.line), class: "line-tile line-tile--#{line.status}", title: "#{line.line}: #{line.delayed? ? "+#{line.max_delay_minutes} min" : "on time"}" do %>
              <span class="line-tile__badge" style="background:<%= line.category_color %>"><%= line.line %></span>
              <% if line.delayed? %>
                <span class="line-tile__delay">+<%= line.max_delay_minutes.round %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
