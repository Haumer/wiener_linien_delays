<% content_for :title, "Wiener Linien Delay Analysis" %>

<div class="delays-page">
  <% if @latest_at.nil? %>
    <div class="delays__empty">
      <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
      <p>No data yet. Start the background worker with <code>bin/jobs</code> to begin collecting snapshots.</p>
    </div>
  <% else %>
    <!-- City switcher -->
    <nav class="city-switcher">
      <% @cities.each do |key, config| %>
        <%= link_to delays_path(city: key),
          class: "city-switcher__btn #{key == @city ? 'city-switcher__btn--active' : ''}" do %>
          <%= config[:name] %>
        <% end %>
      <% end %>
    </nav>

    <!-- Hero: the one number -->
    <header class="delays__hero">
      <div class="delays__hero-score delays__hero-score--<%= @network_ontime >= 85 ? 'good' : @network_ontime >= 70 ? 'fair' : 'poor' %>">
        <span class="delays__hero-number"><%= @network_ontime %>%</span>
        <span class="delays__hero-label">on time</span>
      </div>
      <div class="delays__hero-context">
        <h1><%= @city_config[:name] %> Delay Analysis</h1>
        <p>
          <%= @current_health.size %> lines monitored · <%= @current_health.select(&:delayed?).size %> currently delayed ·
          Updated <%= time_ago_in_words(@latest_at) %> ago
        </p>
        <% if @worst_now.any? %>
          <p class="delays__hero-worst">
            Worst right now:
            <% @worst_now.each do |line| %>
              <%= link_to line_delays_path(city: @city, line: line.line), class: "delays__inline-badge", style: "background:#{line.category_color}" do %><%= line.line %> +<%= line.max_delay_minutes.round %>m<% end %>
            <% end %>
          </p>
        <% end %>
      </div>
      <nav class="delays__nav">
        <%= link_to root_path, class: "delays__back-link" do %>
          <i class="fa-solid fa-map" aria-hidden="true"></i> Live Map
        <% end %>
      </nav>
    </header>

    <!-- Network delay trend -->
    <section class="delays__chart-section">
      <h2>Network Delay Trend</h2>
      <p class="delays__chart-hint">Average delay across all lines, 24-hour rolling window</p>
      <%= area_chart @delay_over_time,
        suffix: " min",
        colors: ["#f59e0b"],
        library: {
          scales: { y: { beginAtZero: true } },
          elements: { point: { radius: 0 }, line: { tension: 0.3 } },
          plugins: { legend: { display: false } }
        },
        height: "200px" %>
    </section>

    <!-- Top bottleneck stations (network-wide) -->
    <% if @top_bottlenecks.any? %>
      <section class="delays__chart-section">
        <h2>Network Bottleneck Stations</h2>
        <p class="delays__chart-hint">Stations where delays concentrate most across the entire network</p>
        <div class="delays__table-wrap">
          <table class="delays__table">
            <thead>
              <tr><th>Station</th><th>Line</th><th>Avg Delay</th><th>Occurrences</th></tr>
            </thead>
            <tbody>
              <% @top_bottlenecks.each do |stop, line, avg_delay, count| %>
                <tr>
                  <td><strong><%= stop %></strong></td>
                  <td>
                    <%= link_to line_delays_path(city: @city, line: line), class: "delays__line-link" do %>
                      <span class="delays__line-badge" style="background:#64748b"><%= line %></span>
                    <% end %>
                  </td>
                  <td><%= (avg_delay.to_f / 60).round(1) %> min</td>
                  <td><%= count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>

    <!-- Line reliability ranking -->
    <section class="delays__chart-section">
      <h2>Line Reliability Ranking</h2>
      <p class="delays__chart-hint">On-time percentage over the last 24 hours — click any line for detailed analysis</p>
      <div class="delays__table-wrap">
        <table class="delays__table">
          <thead>
            <tr><th>Line</th><th>Type</th><th>Reliability</th><th>Avg Delay</th><th>Grade</th></tr>
          </thead>
          <tbody>
            <% @line_rankings.each do |r| %>
              <tr>
                <td>
                  <%= link_to line_delays_path(city: @city, line: r[:line]), class: "delays__line-link" do %>
                    <span class="delays__line-badge" style="background:<%= r[:color] || '#64748b' %>"><%= r[:line] %></span>
                  <% end %>
                </td>
                <td class="delays__category"><%= OebbTransitSupport::CATEGORY_CONFIG.dig(r[:category], :label) || r[:category] %></td>
                <td><strong><%= r[:score] %>%</strong></td>
                <td><%= r[:avg_delay] %> min</td>
                <td>
                  <% grade = if r[:score] >= 95 then "A" elsif r[:score] >= 85 then "B" elsif r[:score] >= 70 then "C" elsif r[:score] >= 50 then "D" else "F" end %>
                  <span class="grade-badge grade-badge--<%= grade %>"><%= grade %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Line grid -->
    <section class="delays__chart-section">
      <h2>All Lines</h2>
      <% @current_health.group_by(&:category).each do |category, lines| %>
        <% config = OebbTransitSupport::CATEGORY_CONFIG[category] || { label: category } %>
        <p class="delays__grid-category"><%= config[:label] %></p>
        <div class="delays__line-grid">
          <% lines.sort_by { |l| l.line.to_i == 0 ? l.line : l.line.to_i.to_s.rjust(5, "0") }.each do |line| %>
            <%= link_to line_delays_path(city: @city, line: line.line), class: "line-tile line-tile--#{line.status}", title: "#{line.line}: #{line.delayed? ? "+#{line.max_delay_minutes} min" : "on time"}" do %>
              <span class="line-tile__badge" style="background:<%= line.category_color %>"><%= line.line %></span>
              <% if line.delayed? %>
                <span class="line-tile__delay">+<%= line.max_delay_minutes.round %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
